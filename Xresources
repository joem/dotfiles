!!! .Xresources file !!!
! Comments start with !, C style #define statements can be used only if
! this file is processed with xrdb -merge $HOME/.Xresources

!#ifdef COLOR
!*customization:	-color
!#endif

!bah.... I can't do any better than the default XTerm font. Oh well.
!#define FONT -b&h-lucidatypewriter-bold-r-normal-sans-12-120-75-75-m-70-iso8859-1
!#define FONT -*-fixed-medium-r-*-*-18-*-*-*-*-*-iso8859-*
!#define FONT -*-bitstream vera sans mono-medium-r-*-*-10-*-*-*-*-*-*-*
!#define FONT -*-dejavu sans mono-medium-r-*-*-11-*-*-*-*-*-*-*
!XTerm*font: FONT

XTerm*foreground:       white
XTerm*background:       black
XTerm*cursorColor:      white
!XTerm*loginShell:       true
!XTerm.vt100.geometry:   79x25
!XTerm*reverseWrap:      true
!XTerm*scrollKey:        true
!XTerm*saveLines:        2000
XTerm*scrollBar:        true
!XTerm*scrollTtyOutput:  false

UXTerm*foreground:       white
UXTerm*background:       black
UXTerm*cursorColor:      white
!UXTerm*loginShell:       true

!XLock.qix.delay:	20000
!XLock.qix.batchcount:	32
!XLock.qix.saturation:	1
!XLock.mode:	qix
!XLock.background:	black
!XLock.foreground:	red
!
!xman*font:				FONT
!xman*manualFontNormal:	-b&h-lucidatypewriter-medium-r-*-*-12-*
!xman*manualFontBold:	FONT
!xman*manualFontItalic:	FONT
!
!emacs-19*font:	FONT
!emacs*font: 	FONT
!
!MXTerm*fontList: FONT
!! enable PageUp and PageDown keys
!MXTerm*vt100*translations: #override\n\
!	<Key>osfPageUp: scroll-back(1,halfpage)\n\
!	<Key>osfPageDown: scroll-forw(1,halfpage)
!
!editres.geometry:	380x450
!
!YTalk.font: -b&h-lucidatypewriter-medium-r-*-*-10-*
!YTalk.geometry: 40x13
!
!Fig*background: gray80
!
!XRload*background: gray65
!XRload*font: -adobe-times-*-r-normal-*-12-*-*-*-*-75-*-*
!
!Ghostview*showDate:      false
!Ghostview*showLocator:   false
!Ghostview*magstep:       -2
!Ghostview.palette:       Monochrome
!Ghostview.Labels:        False
!
!Pixmap.geometry: 653x758
!

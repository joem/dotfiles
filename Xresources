!Axe*buttonList: sftext sline ipaste dcut mundo mform mpref wfull fload fsave fsvas qsvclw
!Axe*tabEvery:      4
!Axe*undoLevel:             1000
!
!Netscape*XmTextField.background:        steelblue3
!Netscape*XmText.background:             steelblue3
